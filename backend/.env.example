# ============================================================
# ForensicStack — Environment Variables Template
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in secrets:  python ../scripts/generate_secrets.py
# 3. Never commit .env to git!
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=forensicstack
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=forensicstack
POSTGRES_HOST=localhost
POSTGRES_PORT=5433        # Host port — maps to container port 5432

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password_min12chars
MINIO_ENDPOINT=localhost:9000
# These mirror ROOT_USER/PASSWORD for the SDK client
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password_min12chars

# ── JWT Authentication ───────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440    # 24 hours

# ── ChromaDB (semantic search) ───────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Application ─────────────────────────────────────────────
DEBUG=true

# ── Docker DooD path mapping ─────────────────────────────────
# Required on Windows when the worker runs in Docker (DooD).
# Set to the absolute host path of the backend/ directory.
# Example (Windows):  HOST_BACKEND_DIR=C:\Users\YourName\forensick_stack\backend
# Example (Linux):    HOST_BACKEND_DIR=/home/yourname/forensick_stack/backend
# Leave empty if running everything natively (not via docker-compose).
HOST_BACKEND_DIR=
