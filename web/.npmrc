# ForensicStack — npm configuration
# ─────────────────────────────────────────────────────────────────────────────
# audit=false   : suppresses "npm audit" warnings after install.
#                 Running "npm audit fix --force" upgrades Next.js across
#                 major versions (14→16) and breaks the build.
#                 Vulnerabilities are tracked manually in package.json.
#
# fund=false    : suppresses funding messages (noise reduction).
#
# save-exact=true : npm install <pkg> saves exact version (no ^ prefix),
#                   consistent with our pinning strategy.
# ─────────────────────────────────────────────────────────────────────────────
audit=false
fund=false
save-exact=true
